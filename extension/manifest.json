{
  "manifest_version": 3,
  "name": "Next Up",
  "version": "1.0.0",
  "description": "Your visual action inbox. Capture screenshots, write action steps, and track progress — all in your new tab.",
  "permissions": ["tabs", "activeTab", "storage", "scripting"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Next Up",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
